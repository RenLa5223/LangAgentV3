{
  "productName": "LangAgentV3",
  "version": "1.0.4",
  "identifier": "com.langagent.v3.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build && python scripts/build_engine.py"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "LangAgent V3",
        "width": 1100,
        "height": 750,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "visible": false,
        "additionalBrowserArgs": "--use-fake-ui-for-media-stream"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "bin/core-engine"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerHooks": "./installer.nsh"
      }
    },
    "publisher": "RenLa",
    "copyright": "",
    "category": "DeveloperTool",
    "shortDescription": "LangAgent",
    "longDescription": "本地运行的 Agent"
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
